# ── Polymarket hosts (read-only, no auth needed for the MVP) ──
# Defaults are baked into lib/polymarket/client.ts; override only if needed.
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_DATA_HOST=https://data-api.polymarket.com

# ── Kalshi host (read-only public trade API v2, no auth) ──
# Powers the cross-venue linker (/link) that ties Kalshi markets to Polymarket bets.
# Default is baked into lib/kalshi/client.ts; override only if needed.
KALSHI_HOST=https://api.elections.kalshi.com/trade-api/v2

# ── Proprietary history capture (the moat). Optional. ──
# If unset, the app still runs fully on-demand; the cron snapshot just no-ops.
# DATABASE_URL=postgres://user:pass@host/db
# REQUIRED to expose the cron endpoint: auth FAILS CLOSED, so if CRON_SECRET is unset
# /api/cron/snapshot returns 401 for everyone (Vercel Cron injects this header itself).
CRON_SECRET=

# ── LLM explanation layer (optional). If unset, the deterministic template is used. ──
# Uses the Vercel AI Gateway with "provider/model" strings.
# AI_GATEWAY_API_KEY=

# ── Relation engine (/discover). Stage-1 semantic recall (embeddings) still uses the AI gateway and
# is optional (lexical recall otherwise). Stage-2 relation classification is UNIFIED on Qwen below;
# the LLM output is a textual HYPOTHESIS only — it never asserts an exact structural relation or a
# numeric correlation, and uncalibrated hypotheses stay ineligible for hedge recommendations. ──
HEDGE_EMBED_MODEL=openai/text-embedding-3-small
QWEN_EMBED_MODEL=text-embedding-v4
# Set false to avoid the paid embedding endpoint; a cached batched LLM shortlist is used when the
# relation API key exists, with lexical recall as the final network-free fallback.
HEDGE_ENABLE_SEMANTIC_EMBEDDINGS=true

# Qwen relation classifier (lib/association). Empty/unset is safe: Qwen calls are skipped and only
# deterministic structural + settlement-calibrated legs feed the robust optimizer.
# DASHSCOPE_API_KEY=
# QWEN_API_KEY=
# Ordered failover; the NEXT model is tried on quota/rate-limit/model/output failures, in this order.
# See /api/diag/stats modelTelemetry for live success/timeout/fallback rates.
QWEN_RELATION_MODELS=deepseek-r1,deepseek-v4-pro,MiniMax-M2.1,qwen-flash,kimi-k2.5,kimi-k2.6,qwen-plus-1220
HEDGE_RELATION_JOB_CONCURRENCY=8
# Persistent PostgreSQL + in-process cache for stable recall/classification inputs (1–720 hours).
HEDGE_LLM_CACHE_TTL_HOURS=168
# Legacy single-model override (optional; omit when using the chain above).
# QWEN_RELATION_MODEL=deepseek-r1
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_RELATION_TIMEOUT_MS=45000
HEDGE_EXPLAIN_MODEL=anthropic/claude-haiku-4.5

# ── Default MVP scope ──
# The single deeply-liquid negRisk event we ship v1 against.
HEDGE_DEFAULT_EVENT_SLUG=world-cup-winner

# Live relation-candidate catalog. Comma-separated; extend this without editing source.
HEDGE_RELATE_PM_EVENTS=world-cup-winner,world-cup-golden-boot-winner,which-continent-will-win-the-world-cup,world-cup-nation-to-reach-final,world-cup-group-d-winner
HEDGE_RELATE_KALSHI_SERIES=KXMENWORLDCUP,KXWCCONTINENT,KXWCGROUPWINNER,KXWCFIRSTSONG

# Settlement calibration. With no JSON, the route uses the single current-event fallback below.
HEDGE_SETTLE_CLUSTER=wc2026
HEDGE_KALSHI_NARRATIVE_SERIES=KXWCFIRSTSONG
HEDGE_KALSHI_EVENT_NEEDLE=2026
# For statistically useful backfill, configure one entry per independent historical event instance.
# Invalid JSON fails closed so samples cannot silently land in the wrong cluster.
# Set llmMechanisms=true to classify reusable cross-entity/cross-domain mechanisms during backfill.
# maxLlmPairs is a hard per-run cost/latency cap.
# HEDGE_SETTLE_JOBS_JSON=[{"cluster":"wc2026","category":"world-cup","anchorSlug":"world-cup-winner","anchorEntities":["Spain"],"candidateSlugs":["world-cup-nation-to-reach-final"],"kalshiSeries":["KXWCFIRSTSONG"],"kalshiEventTickers":[],"kalshiEventNeedle":"2026","llmMechanisms":true,"maxLlmPairs":40}]
# Point-in-time candidate snapshots. Keep topK small: the LLM classifies these before settlement and
# the protected walk-forward backtest refuses pairs that were not present in this table beforehand.
# Spread the anchors ACROSS DOMAINS so the calibration training set is not concentrated in sports/macro.
# If unset, the code falls back to a diverse multi-domain default (see app/api/cron/relations/route.ts).
# HEDGE_RELATION_SNAPSHOT_JOBS_JSON=[{"query":"Spain wins the 2026 World Cup","topK":4},{"query":"Lakers win the 2026 NBA championship","topK":4},{"query":"Donald Trump job approval above 45 percent","topK":4},{"query":"Republicans win the 2026 Senate majority","topK":4},{"query":"Bitcoin above 100000 dollars in 2026","topK":4},{"query":"Federal Reserve cuts interest rates in 2026","topK":4},{"query":"OpenAI releases GPT-5 in 2026","topK":4},{"query":"2026 Academy Award Best Picture winner","topK":4}]
# Number of current open Polymarket event bundles added to the cross-domain discovery universe.
HEDGE_RELATE_PM_TOP_EVENTS=24
# Number of current open Kalshi events added independently of configured series.
HEDGE_RELATE_KALSHI_TOP_EVENTS=24
